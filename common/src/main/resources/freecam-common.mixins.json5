{
  "required": true,
  "package": "net.xolt.freecam.mixins",
  "plugin": "net.xolt.freecam.FreecamMixinConfig",
  "compatibilityLevel": "${mixinCompatLevel}",
  "minVersion": "0.8",
  "client": [
    "AvatarRendererMixin",
    "BlockStateBaseMixin",
    "CameraMixin",
    "ClientPacketListenerMixin",
    "EntityMixin",
    "EntityRenderDispatcherMixin",
    "FullBrightMixin",
    "GameRendererMixin",
    "GuiMixin",
    "IrisHandRendererMixin",
    //? if <1.21.6
    //"IrisShadowRendererMixin",
    "ItemInHandRendererMixin",
    "LivingEntityMixin",
    "LocalPlayerMixin",
    "MinecraftMixin",
    "MultiPlayerGameModeMixin",
    "OptionsMixin"
  ],
  "injectors": {
    "defaultRequire": 1
  }
}
